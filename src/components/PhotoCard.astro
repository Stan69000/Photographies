---
interface Photo {
  id: string;
  slug: string;
  title: string;
  description?: string;
  url: string;
}

interface Props {
  photo: Photo;
  index: number;
}

const { photo, index } = Astro.props;
---

<article class="photo-card reveal">
  <button
    type="button"
    class="card-trigger"
    data-lightbox-index={index}
    aria-label={`Ouvrir ${photo.title} en plein écran`}
  >
    <img
      src={photo.url}
      alt={photo.title}
      loading="lazy"
      decoding="async"
      style={`view-transition-name: photo-${photo.slug};`}
    />
    <div class="overlay">
      <div class="overlay-top">
        <button type="button" class="vote-btn" data-vote-btn data-vote-slug={photo.slug} aria-label="Voter">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <strong data-vote-count data-vote-slug={photo.slug}>0</strong>
        </button>
      </div>
      <div class="overlay-bottom">
        <a href={`/photo/${photo.slug}/`} class="card-title" onclick="event.stopPropagation()">{photo.title}</a>
        {photo.description && <p class="card-desc">{photo.description}</p>}
      </div>
    </div>
  </button>
</article>

<style>
  .photo-card {
    break-inside: avoid;
    margin-bottom: 1rem;
  }

  .card-trigger {
    display: block;
    width: 100%;
    border: 0;
    padding: 0;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    cursor: zoom-in;
    position: relative;
  }

  img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.75rem;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.5) 0%,
      transparent 35%,
      transparent 55%,
      rgba(0, 0, 0, 0.72) 100%
    );
    opacity: 0;
    transition: opacity 320ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-trigger:hover .overlay {
    opacity: 1;
  }

  .card-trigger:hover img {
    transform: scale(1.04);
  }

  .overlay-top {
    display: flex;
    justify-content: flex-end;
  }

  .vote-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(8px);
    color: #fff;
    border-radius: 999px;
    padding: 0.3rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 200ms ease, border-color 200ms ease;
  }

  .vote-btn:hover {
    background: rgba(116, 143, 255, 0.35);
    border-color: rgba(116, 143, 255, 0.6);
  }

  .vote-btn:disabled {
    opacity: 0.55;
    cursor: default;
  }

  .vote-btn svg {
    flex-shrink: 0;
  }

  .overlay-bottom {
    display: grid;
    gap: 0.2rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 400;
    color: #f2f7ff;
    line-height: 1.2;
    display: block;
  }

  .card-title:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .card-desc {
    margin: 0;
    font-size: 0.82rem;
    color: rgba(210, 225, 255, 0.8);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

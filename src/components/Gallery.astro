---
import PhotoCard from './PhotoCard.astro';
import Lightbox from './Lightbox.astro';

interface Item {
  id: string;
  slug: string;
  title: string;
  description?: string;
  url: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<section>
  <div class="masonry">
    {items.map((photo, index) => (
      <PhotoCard photo={photo} index={index} />
    ))}
  </div>
  <Lightbox photos={items} />
</section>

<style>
  .masonry {
    column-count: 1;
    column-gap: 1rem;
  }

  @media (min-width: 720px) {
    .masonry {
      column-count: 2;
    }
  }

  @media (min-width: 1080px) {
    .masonry {
      column-count: 3;
    }
  }
</style>
